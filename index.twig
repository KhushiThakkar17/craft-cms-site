{% extends "_layout" %}

{% block title %}Home{% endblock %}

{% block content %}
  <section style="background:#f5f5f5; padding:40px; border-left:5px solid #c41230; margin-bottom:40px;">
    <h2 style="font-size:28px; margin-bottom:12px; color:#1a1a2e;">Supporting Research Excellence at UMD</h2>
    <p style="font-size:16px; line-height:1.6; margin-bottom:20px;">
      The Office of Research Administration provides comprehensive support for the 
      research community at the University of Maryland, College Park.
    </p>
    <a href="/contact" style="background:#c41230; color:white; padding:10px 24px; text-decoration:none; border-radius:4px;">Get in Touch</a>
  </section>

  <section style="display:flex; gap:20px; flex-wrap:wrap;">
    {% set announcements = craft.entries.section('news').limit(3).all() %}
    {% for entry in announcements %}
      <div style="flex:1; min-width:250px; border:1px solid #ddd; border-top:4px solid #c41230; padding:24px; border-radius:4px;">
        <h3 style="margin-bottom:10px; color:#1a1a2e;">{{ entry.title }}</h3>
        <p style="font-size:14px; color:#666;">{{ entry.postDate|date('M d, Y') }}</p>
      </div>
    {% else %}
      <p>No announcements at this time.</p>
    {% endfor %}
  </section>
{% endblock %}
