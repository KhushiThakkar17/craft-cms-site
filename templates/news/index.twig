{% extends "_layout" %}

{% block title %}News{% endblock %}

{% block content %}
  <h2 style="margin-bottom:24px; color:#1a1a2e; border-left:4px solid #c41230; padding-left:12px;">Latest News</h2>

  {% set entries = craft.entries.section('news').orderBy('postDate desc').all() %}
  {% for entry in entries %}
    <div style="border:1px solid #ddd; padding:24px; margin-bottom:20px; border-radius:4px;">
      <h3 style="margin-bottom:8px;"><a href="{{ entry.url }}" style="color:#1a1a2e; text-decoration:none;">{{ entry.title }}</a></h3>
      <p style="font-size:13px; color:#888; margin-bottom:10px;">{{ entry.postDate|date('F d, Y') }}</p>
      <p style="font-size:14px; line-height:1.6;">{{ entry.summary ?? entry.title }}</p>
    </div>
  {% else %}
    <p>No news entries found.</p>
  {% endfor %}
{% endblock %}
