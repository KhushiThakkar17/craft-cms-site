{% extends "_layout" %}

{% block title %}Resources{% endblock %}

{% block content %}
  <h2 style="margin-bottom:24px; color:#1a1a2e; border-left:4px solid #c41230; padding-left:12px;">Resources</h2>

  {% set resources = craft.entries.section('resources').orderBy('title asc').all() %}
  <div style="display:flex; gap:20px; flex-wrap:wrap;">
    {% for resource in resources %}
      <div style="flex:1; min-width:250px; border:1px solid #ddd; border-top:4px solid #c41230; padding:24px; border-radius:4px;">
        <h3 style="margin-bottom:10px; color:#1a1a2e;">{{ resource.title }}</h3>
        <p style="font-size:14px; line-height:1.6;">{{ resource.description ?? 'Click to learn more.' }}</p>
      </div>
    {% else %}
      <p>No resources found.</p>
    {% endfor %}
  </div>
{% endblock %}
