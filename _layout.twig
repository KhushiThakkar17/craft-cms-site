<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}ORA{% endblock %} | University of Maryland</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Arial, sans-serif; color: #333; }
    header { background: #c41230; color: white; padding: 20px 40px; }
    header h1 { font-size: 22px; }
    nav { background: #1a1a2e; display: flex; }
    nav a { color: white; text-decoration: none; padding: 14px 24px; font-size: 14px; }
    nav a:hover { background: #c41230; }
    main { max-width: 1100px; margin: 40px auto; padding: 0 20px; }
    footer { background: #1a1a2e; color: white; text-align: center; padding: 20px; margin-top: 60px; font-size: 13px; }
  </style>
</head>
<body>
  <header>
    <h1>Office of Research Administration</h1>
    <p>University of Maryland, College Park</p>
  </header>
  <nav>
    <a href="/">Home</a>
    <a href="/news">News</a>
    <a href="/staff">Staff Directory</a>
    <a href="/resources">Resources</a>
    <a href="/contact">Contact</a>
  </nav>
  <main>
    {% block content %}{% endblock %}
  </main>
  <footer>
    <p>© {{ now|date('Y') }} Office of Research Administration | University of Maryland</p>
  </footer>
</body>
</html>
